<section class="relative overflow-hidden pt-40 pb-40">

	<!-- Background -->
	<div class="absolute inset-0 z-0 overflow-hidden">
		<div
			class="absolute left-0 top-0 h-[500px] w-[500px] rounded-full blur-3xl"
			style="background: var(--color-primary); opacity: 0.1;"
		></div>

		<div
			class="absolute right-0 top-32 h-[400px] w-[400px] rounded-full blur-3xl"
			style="background: var(--color-primary); opacity: 0.05;"
		></div>
	</div>

	<div class="section-container relative z-10">

		<div class="grid gap-16 lg:grid-cols-2 lg:items-center">

			<!-- LEFT -->
			<header>

				<p class="mb-2 text-sm uppercase tracking-[0.3em]"
				   style="color: var(--color-text-muted);">
					Российские лазерные тренировочные комплексы
				</p>

				<span
					class="mb-4 inline-block rounded-full border px-4 py-1 text-sm"
					style="border-color: var(--color-primary-dark); color: var(--color-primary);"
				>
					Современные средства стрелковой подготовки
				</span>

				<h1
					class="mb-8 text-4xl font-bold leading-tight sm:text-5xl md:text-7xl"
					style="color: var(--color-text);"
				>
					Лазерные тренировочные комплексы
				</h1>

				<p
					class="mb-12 max-w-3xl text-lg leading-relaxed md:text-xl"
					style="color: var(--color-text-muted);"
				>
					Подготовка личного состава, курсантов и стрелков
					в условиях, максимально приближенных к реальным,
					без расхода боеприпасов и необходимости посещения полигона.
				</p>

				<!-- CTA (converted to primitives) -->
				<div class="mb-16 flex flex-wrap gap-4">

					<a href="#contacts" class="btn-primary">
						Запросить демонстрацию
					</a>

					<a href="#technology" class="btn-secondary">
						О технологии
					</a>

				</div>

				<!-- KPI (converted to card primitive) -->
				<div class="grid gap-6 md:grid-cols-3">

					<div class="card">
						<p class="mb-2 text-3xl font-bold"
						   style="color: var(--color-primary);">
							24/7
						</p>
						<p class="text-sm"
						   style="color: var(--color-text-muted);">
							Возможность тренировок в помещении
						</p>
					</div>

					<div class="card">
						<p class="mb-2 text-3xl font-bold"
						   style="color: var(--color-primary);">
							0
						</p>
						<p class="text-sm"
						   style="color: var(--color-text-muted);">
							Расход боеприпасов во время обучения
						</p>
					</div>

					<div class="card">
						<p class="mb-2 text-3xl font-bold"
						   style="color: var(--color-primary);">
							∞
						</p>
						<p class="text-sm"
						   style="color: var(--color-text-muted);">
							Количество тренировочных сценариев
						</p>
					</div>

				</div>

			</header>

			<!-- RIGHT -->
			<aside class="card">

				<h2 class="mb-6 text-2xl font-semibold"
					style="color: var(--color-primary);">
					Основные возможности
				</h2>

				<ul class="space-y-4">

					<li class="flex gap-3">
						<span style="color: var(--color-primary);">✓</span>
						<span style="color: var(--color-text);">
							Подготовка стрелков любого уровня
						</span>
					</li>

					<li class="flex gap-3">
						<span style="color: var(--color-primary);">✓</span>
						<span style="color: var(--color-text);">
							Детальная статистика результатов
						</span>
					</li>

					<li class="flex gap-3">
						<span style="color: var(--color-primary);">✓</span>
						<span style="color: var(--color-text);">
							Работа в помещении круглый год
						</span>
					</li>

					<li class="flex gap-3">
						<span style="color: var(--color-primary);">✓</span>
						<span style="color: var(--color-text);">
							Настраиваемые тренировочные сценарии
						</span>
					</li>

					<li class="flex gap-3">
						<span style="color: var(--color-primary);">✓</span>
						<span style="color: var(--color-text);">
							Отсутствие расхода боеприпасов
						</span>
					</li>

					<li class="flex gap-3">
						<span style="color: var(--color-primary);">✓</span>
						<span style="color: var(--color-text);">
							Безопасное обучение и отработка навыков
						</span>
					</li>

				</ul>

			</aside>

		</div>

	</div>

</section>
