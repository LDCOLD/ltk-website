---
const items = [
	{
		title: "Экономия ресурсов",
		text: "Снижение затрат на боеприпасы и организацию тренировочного процесса."
	},
	{
		title: "Безопасность",
		text: "Проведение тренировок без риска, связанного с боевой стрельбой."
	},
	{
		title: "Объективная оценка",
		text: "Автоматическая фиксация результатов каждого упражнения."
	},
	{
		title: "Гибкость",
		text: "Настройка сценариев под различные задачи и уровни подготовки."
	},
	{
		title: "Круглогодичная работа",
		text: "Обучение вне зависимости от сезона и погодных условий."
	},
	{
		title: "Масштабируемость",
		text: "Возможность внедрения как в небольших классах, так и в крупных центрах."
	}
];
---

<section id="advantages" class="py-24">
	<div class="section-container">

		<h2 class="mb-12 text-4xl font-bold"
			style="color: var(--color-text);">
			Ключевые преимущества
		</h2>

		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">

			{items.map((item) => (
				<article class="card">

					<h3 class="mb-3 text-xl font-semibold"
						style="color: var(--color-primary);">
						{item.title}
					</h3>

					<p style="color: var(--color-text-muted);">
						{item.text}
					</p>

				</article>
			))}

		</div>

	</div>
</section>