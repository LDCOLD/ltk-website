---
const navItems = [
  { label: "Технология", href: "#technology" },
  { label: "Применение", href: "#applications" },
  { label: "Комплексы", href: "#products" },
  { label: "Преимущества", href: "#advantages" },
  { label: "Контакты", href: "#contacts" }
];
---

<header
	class="sticky top-0 z-50 backdrop-blur-md"
	style={{
		background: "rgba(9, 9, 11, 0.85)",
		borderBottom: "1px solid var(--color-border)"
	}}
>
	<div class="section-container">
		<div class="flex items-center justify-between h-16">

			<a
				href="/"
				class="text-lg font-bold tracking-wide"
				style={{ color: "var(--color-primary)" }}
			>
				ЛТК
			</a>

			<!-- Desktop nav -->
			<nav
				class="hidden md:flex gap-8 text-sm"
				style={{ color: "var(--color-text-muted)" }}
			>
				{navItems.map((item) => (
					<a
						href={item.href}
						class="transition-colors"
						style={{ color: "inherit" }}
						onMouseOver={(e) =>
							(e.currentTarget.style.color = "var(--color-text)")
						}
						onMouseOut={(e) =>
							(e.currentTarget.style.color = "var(--color-text-muted)")
						}
					>
						{item.label}
					</a>
				))}
			</nav>

			<!-- Mobile button -->
			<button
				id="menuBtn"
				class="md:hidden"
				style={{ color: "var(--color-text-muted)" }}
				aria-label="Open menu"
				aria-expanded="false"
			>
				Меню
			</button>

		</div>

		<!-- Mobile menu -->
		<nav
			id="mobileMenu"
			class="fixed top-0 right-0 hidden h-screen w-72 flex-col gap-6 p-8 md:hidden"
			style="
				background: var(--color-bg-secondary);
				border-left: 1px solid var(--color-border);
			"
		>
		{navItems.map((item) => (
			<a
				href={item.href}
				class="text-lg"
				style="color: var(--color-text);"
			>
				{item.label}
			</a>
		))}
		</nav>
	</div>

	<script is:inline>
		const btn = document.getElementById("menuBtn");
		const menu = document.getElementById("mobileMenu");
		const overlay = document.getElementById("menuOverlay");

		btn?.addEventListener("click", () => {
			menu.classList.toggle("hidden");
			overlay.classList.toggle("hidden");

			const isOpen = !menu.classList.contains("hidden");
			btn.setAttribute("aria-expanded", String(isOpen));
		});

		overlay?.addEventListener("click", () => {
			menu.classList.add("hidden");
			overlay.classList.add("hidden");
			btn?.setAttribute("aria-expanded", "false");
		});
	</script>
</header>