---
const navItems = [
	{ label: "Технология", href: "#technology" },
	{ label: "Применение", href: "#applications" },
	{ label: "Комплексы", href: "#products" },
	{ label: "Преимущества", href: "#advantages" },
	{ label: "Контакты", href: "#contacts" }
];
---

<header
	class="sticky top-0 z-50 backdrop-blur-md"
	style={{
		background: "rgba(9, 9, 11, 0.85)",
		borderBottom: "1px solid var(--color-border)"
	}}
>
	<div class="section-container">
		<div class="flex h-16 items-center justify-between">

			<a
				href="/"
				class="text-lg font-bold tracking-wide"
				style={{ color: "var(--color-primary)" }}
			>
				ЛТК
			</a>

			<!-- Desktop nav -->
			<nav
				class="hidden gap-8 text-sm md:flex"
				style={{ color: "var(--color-text-muted)" }}
			>
				{navItems.map((item) => (
					<a
						href={item.href}
						class="transition-colors hover:text-white"
					>
						{item.label}
					</a>
				))}
			</nav>

			<!-- Mobile button -->
			<button
				id="menuBtn"
				class="text-2xl md:hidden"
				style={{ color: "var(--color-text)" }}
				aria-label="Открыть меню"
				aria-expanded="false"
			>
				☰
			</button>

		</div>
	</div>
</header>

<!-- Overlay -->
<div
	id="menuOverlay"
	class="fixed inset-0 z-[90] hidden bg-black/60"
></div>

<!-- Mobile menu -->
<nav
	id="mobileMenu"
	class="fixed top-0 right-0 z-[100] hidden h-screen w-72 flex-col gap-6 p-8"
	style="
		background: var(--color-bg-secondary);
		border-left: 1px solid var(--color-border);
	"
>
	<div class="mb-4 flex items-center justify-between">

		<span
			class="text-lg font-semibold"
			style="color: var(--color-primary);"
		>
			Меню
		</span>

		<button
			id="closeMenuBtn"
			class="text-2xl"
			style="color: var(--color-text-muted);"
			aria-label="Закрыть меню"
		>
			✕
		</button>

	</div>

	{navItems.map((item) => (
		<a
			href={item.href}
			class="mobile-link block text-lg"
			style="color: var(--color-text);"
		>
			{item.label}
		</a>
	))}
</nav>

<script is:inline>
	const btn = document.getElementById("menuBtn");
	const closeBtn = document.getElementById("closeMenuBtn");
	const menu = document.getElementById("mobileMenu");
	const overlay = document.getElementById("menuOverlay");
	const links = document.querySelectorAll(".mobile-link");

	function openMenu() {
		menu.classList.remove("hidden");
		menu.classList.add("flex");

		overlay.classList.remove("hidden");

		document.body.style.overflow = "hidden";

		btn?.setAttribute("aria-expanded", "true");
	}

	function closeMenu() {
		menu.classList.add("hidden");
		menu.classList.remove("flex");

		overlay.classList.add("hidden");

		document.body.style.overflow = "";

		btn?.setAttribute("aria-expanded", "false");
	}

	btn?.addEventListener("click", () => {
		if (menu.classList.contains("hidden")) {
			openMenu();
		} else {
			closeMenu();
		}
	});

	closeBtn?.addEventListener("click", closeMenu);

	overlay?.addEventListener("click", closeMenu);

	links.forEach((link) => {
		link.addEventListener("click", closeMenu);
	});

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeMenu();
		}
	});
</script>